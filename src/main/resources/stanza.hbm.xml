<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "https://hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.appprenotazione.model">
    <class name="Stanza" table="stanza">
        <id name="id" type="java.lang.Integer">
            <column name="id"/>
            <generator class="identity"/>
        </id>

        <property name="nStanza" type="java.lang.String">
            <column name="n_stanza"/>
        </property>

        <bag name="listaPostazioni" cascade="all">
            <key column="id_stanza"></key>
            <one-to-many class="com.appprenotazione.model.Postazione"/>
        </bag>

        <many-to-one name="sede" class="com.appprenotazione.model.Sede">
            <column name="id_sede"></column>
        </many-to-one>
    </class>


</hibernate-mapping>