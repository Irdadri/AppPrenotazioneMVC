<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "https://hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.appprenotazione.model">
    <class name="Postazione" table="postazione">
        <id name="id" type="java.lang.Integer">
            <column name="id"/>
            <generator class="identity"/>
        </id>

        <property name="manutenzione" type="java.lang.Boolean">
            <column name="manutenzione"/>
        </property>

        <many-to-one name="stanza" class="com.appprenotazione.model.Stanza">
            <column name="id_stanza"></column>
        </many-to-one>

        <bag name="listaPrenotazioni" cascade="all">
            <key column="id_postazione"></key>
            <one-to-many class="com.appprenotazione.model.Prenotazione"/>
        </bag>

    </class>

</hibernate-mapping>